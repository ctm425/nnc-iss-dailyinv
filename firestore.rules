rules_version = '2';

// NNC Inventory — Firestore Security Rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerEmail() {
      return isSignedIn()
        && request.auth.token.email in [
          'shan.janjua@gmail.com',
          'shan@naanncurry.net'
        ];
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasOwnerRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userRole() == 'owner';
    }

    function isOwner() {
      return hasOwnerRole() || isOwnerEmail();
    }

    // ---------- users ----------
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isOwner());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isOwner()
                    || (isSignedIn() && request.auth.uid == uid
                        && request.resource.data.role == resource.data.role)
                    || (isOwnerEmail() && request.auth.uid == uid);
      allow delete: if isOwner();
    }

    // ---------- config (settings, role-permissions, daily-report) ----------
    // Owner-only writes; managers cannot adjust settings.
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // ---------- days (daily kitchen + produce inventory) ----------
    match /days/{dateKey} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }

    // ---------- edit-requests (HYPHEN — verified against client code) ----------
    match /edit-requests/{reqId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isOwner();
    }

    // ---------- inventory_config + inventory_weeks (drygoods.html) ----------
    match /inventory_config/{doc} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /inventory_weeks/{doc} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }

    // ---------- warehouse_config + warehouse_weeks + warehouse_transfers ----------
    match /warehouse_config/{doc} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /warehouse_weeks/{doc} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /warehouse_transfers/{doc} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }

    // ---------- storage_config + storage_weeks + storage_transfers ----------
    match /storage_config/{doc} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /storage_weeks/{doc} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /storage_transfers/{doc} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }

    // ---------- inter_transfers (transfer-request.html) ----------
    match /inter_transfers/{doc} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }

    // ---------- variance_logs (variance.js) ----------
    match /variance_logs/{doc} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isOwner();
    }

    // ---------- prep + usage logs ----------
    // Path pattern: <collection>/<location>/records/<dateKey>
    // Used by rice-usage-log, chicken-prep-log, tikka-prep-log,
    // produce-prep-log, packing-log, and naan-roti-log.
    // {document=**} matches the parent location doc AND the nested records subcollection.
    match /rice-usage/{document=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /chicken-prep/{document=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /tikka-prep/{document=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /produce-prep/{document=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /packing-log/{document=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /naan-roti-prep/{document=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }
    match /naan-roti-usage/{document=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }

    // ---------- weekly-tasks (weekly-tasks.html) ----------
    // Path: weekly-tasks/<location>/days/<dateKey>
    match /weekly-tasks/{document=**} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isOwner();
    }

    // ---------- caterings (caterings.html, catering-edit.html) ----------
    // OWNER-ONLY for both read AND write — contains customer PII and pricing.
    // Managers and staff must never see or modify caterings.
    // {document=**} covers the booking doc AND its nested comms subcollection
    // (caterings/<id>/comms/<commId> — timestamped call/communication log).
    match /caterings/{document=**} {
      allow read, write: if isOwner();
    }

    // ---------- catering-menu-items (catering-menu.html) ----------
    // OWNER-ONLY. Editable menu (name, description, category, price) uploaded
    // by the owner and picked from on the booking form. HYPHENS, not underscores.
    match /catering-menu-items/{document=**} {
      allow read, write: if isOwner();
    }

    // ---------- default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
